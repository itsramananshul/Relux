{
  "name": "relix-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Relix operator dashboard — Vite + React + TypeScript SPA served by the web bridge at /dashboard.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "test": "node --test --experimental-strip-types",
    "smoke:browser": "node scripts/browser-smoke.mjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.2"
  }
}
